#!/bin/bash

# Poule Developer Launcher
# Usage: poule-dev [--rebuild] [command]
# Builds and runs a dev container with src/ live-mounted from the host.
# Must be run from the poule project root.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$SCRIPT_DIR/.."
DEV_IMAGE="poule:dev"

# Parse arguments
REBUILD=false
ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --rebuild)
            REBUILD=true
            shift
            ;;
        --help|-h)
            echo "Usage: poule-dev [OPTIONS] [COMMAND]"
            echo ""
            echo "Run a dev container with live-mounted source from the poule project root."
            echo "Builds the dev image automatically on first run (uses Dockerfile app-deps stage)."
            echo ""
            echo "OPTIONS:"
            echo "  --rebuild          Force rebuild the dev image"
            echo "  --help, -h         Show this help message"
            echo ""
            echo "EXAMPLES:"
            echo "  poule-dev                         Start interactive dev shell"
            echo "  poule-dev uv run pytest            Run tests with live-mounted source"
            echo "  poule-dev coqc --version            Run a command in the container"
            echo "  poule-dev --rebuild                 Rebuild the dev image and start shell"
            exit 0
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

# Must be run from the poule project root
if [ ! -d "$PROJECT_DIR/src/poule" ]; then
    echo "Error: must be run from the poule project root."
    echo "Expected to find src/poule/ relative to bin/poule-dev"
    exit 1
fi

# Get host user info for proper file ownership
HOST_UID=$(id -u)
HOST_GID=$(id -g)
HOST_USER=$(id -un)
HOST_GROUP=$(id -gn)

# Build dev image if missing or --rebuild requested
DEV_IMAGE_EXISTS=$(docker images --format "{{.Repository}}:{{.Tag}}" | grep -c "^poule:dev$" || echo "0")
if [ "$DEV_IMAGE_EXISTS" -eq 0 ] || [ "$REBUILD" = true ]; then
    echo "Building dev image (app-deps stage, no src/ baked in)..."
    docker build \
        --target app-deps \
        --build-arg HOST_UID="$HOST_UID" \
        --build-arg HOST_GID="$HOST_GID" \
        --build-arg HOST_USER="$HOST_USER" \
        --build-arg HOST_GROUP="$HOST_GROUP" \
        -t "$DEV_IMAGE" \
        "$PROJECT_DIR"
fi

# Persistent home directory
CONTAINER_HOME="$HOME/poule-home"
if [ ! -d "$CONTAINER_HOME" ]; then
    echo "Creating Poule home directory: $CONTAINER_HOME"
    mkdir -p "$CONTAINER_HOME"
fi
chmod 700 "$CONTAINER_HOME"

# Fix SSH key permissions (macOS mounts may have overly permissive modes)
SSH_DIR="$CONTAINER_HOME/.ssh"
if [ -d "$SSH_DIR" ]; then
    chmod 700 "$SSH_DIR"
    find "$SSH_DIR" -maxdepth 1 -type f -name "id_*" ! -name "*.pub" -exec chmod 600 {} \;
    for f in "$SSH_DIR"/*.pub "$SSH_DIR/config" "$SSH_DIR/known_hosts" "$SSH_DIR/authorized_keys"; do
        [ -f "$f" ] && chmod 644 "$f"
    done
fi

# Ensure Claude Code settings and statusline script exist in persistent home
CLAUDE_DIR="$CONTAINER_HOME/.claude"
mkdir -p "$CLAUDE_DIR"

if [ ! -f "$CLAUDE_DIR/settings.json" ]; then
    echo "Initializing Claude Code settings..."
    cat > "$CLAUDE_DIR/settings.json" << 'EOF'
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
EOF
fi

if [ ! -f "$CLAUDE_DIR/statusline.sh" ] || [ "$PROJECT_DIR/docker/statusline.sh" -nt "$CLAUDE_DIR/statusline.sh" ]; then
    cp "$PROJECT_DIR/docker/statusline.sh" "$CLAUDE_DIR/statusline.sh"
    chmod +x "$CLAUDE_DIR/statusline.sh"
fi

# Auto-configure MCP server (SSE transport — upgrade from stdio if needed)
if [ ! -f "$CLAUDE_DIR/mcp.json" ] || grep -q '"command"' "$CLAUDE_DIR/mcp.json" 2>/dev/null; then
    cat > "$CLAUDE_DIR/mcp.json" << 'EOF'
{
  "mcpServers": {
    "coq-search": {
      "url": "http://127.0.0.1:3000/sse"
    }
  }
}
EOF
fi

# Repair incomplete plugin caches
PLUGIN_CACHE="$CLAUDE_DIR/plugins/cache"
PLUGIN_MARKETPLACE="$CLAUDE_DIR/plugins/marketplaces"

if [ -d "$PLUGIN_CACHE" ] && [ -d "$PLUGIN_MARKETPLACE" ]; then
    for marketplace_dir in "$PLUGIN_MARKETPLACE"/*/; do
        marketplace_name=$(basename "$marketplace_dir")
        plugins_source="$marketplace_dir/plugins"
        cache_base="$PLUGIN_CACHE/$marketplace_name"
        [ -d "$plugins_source" ] && [ -d "$cache_base" ] || continue

        for plugin_cache_dir in "$cache_base"/*/; do
            plugin_name=$(basename "$plugin_cache_dir")
            plugin_source="$plugins_source/$plugin_name"
            [ -d "$plugin_source" ] || continue

            for version_dir in "$plugin_cache_dir"/*/; do
                [ -d "$version_dir" ] || continue
                for source_subdir in "$plugin_source"/*/; do
                    [ -d "$source_subdir" ] || continue
                    if [ ! -d "$version_dir/$(basename "$source_subdir")" ]; then
                        echo "Repairing incomplete plugin cache: $plugin_name"
                        rm -rf "$version_dir"
                        break
                    fi
                done
            done
        done
    done
fi

# Create data directory and download index if needed
DATA_DIR="$CONTAINER_HOME/data"
mkdir -p "$DATA_DIR"

if [ ! -f "$DATA_DIR/index.db" ]; then
    echo ""
    if [ -f "$PROJECT_DIR/index.db" ]; then
        echo "Copying local index.db into data directory..."
        cp "$PROJECT_DIR/index.db" "$DATA_DIR/index.db"
        echo "Index copied successfully."
    else
        echo "No local index.db found — downloading from latest GitHub release..."
        # Mount src/ so the CLI module is available for the download command
        if docker run --rm \
            -v "$PROJECT_DIR/src:/app/src" \
            -v "$DATA_DIR:/data" \
            --entrypoint sh \
            "$DEV_IMAGE" \
            -c 'uv run --project /app python -m poule.cli download-index --output /data/index.db'; then
            echo "Index downloaded successfully."
        else
            echo "Warning: Index download failed. You can retry later from inside the container:"
            echo "  uv run --project /app python -m poule.cli download-index --output ~/data/index.db"
        fi
    fi
    echo ""
fi

# Initialize zsh configuration in persistent home
if [ ! -f "$CONTAINER_HOME/.zshrc" ]; then
    cat > "$CONTAINER_HOME/.zshrc" << 'EOF'
# Poule container zsh configuration
_git_branch_colored() {
  local branch=$(git branch --show-current 2>/dev/null)
  if [ -n "$branch" ]; then
    if [ "$branch" = "main" ]; then
      echo "%F{red}[$branch]%f"
    else
      echo "%F{green}[$branch]%f"
    fi
  fi
}
setopt PROMPT_SUBST
PROMPT='%F{cyan}[poule]%f $(_git_branch_colored)%F{blue}[%~]%f$ '
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
export PATH="/opt/opam/coq/bin:$HOME/.local/bin:$PATH"
export UV_LINK_MODE="copy"
alias claude='claude --dangerously-skip-permissions'
EOF
fi

# Ensure Claude Code is installed in the persistent home (fast no-op if present).
# Export PATH first so the installer sees ~/.local/bin (zsh -c doesn't source .zshrc).
INIT_CMD='export PATH="$HOME/.local/bin:$PATH"; ensure-claude'

# Run container with live-mounted source
if [ ${#ARGS[@]} -eq 0 ]; then
    echo "Starting Poule dev environment (live source mount)"
    docker run -it --rm \
        --user "$HOST_UID:$HOST_GID" \
        -v "$PROJECT_DIR/src:/app/src" \
        -v "$PROJECT_DIR/test:/app/test" \
        -v "$PROJECT_DIR/examples:/app/examples" \
        -v "$PROJECT_DIR/CLAUDE.md:/app/CLAUDE.md" \
        -v "$PROJECT_DIR/README.md:/app/README.md" \
        -v "$CONTAINER_HOME:/home/$HOST_USER" \
        -v "$DATA_DIR:/data" \
        -w /app \
        -e HOME="/home/$HOST_USER" \
        -e ANTHROPIC_API_KEY \
        -e TZ="${TZ:-UTC}" \
        "$DEV_IMAGE" \
        zsh -c "$INIT_CMD; exec zsh"
else
    docker run --rm \
        --user "$HOST_UID:$HOST_GID" \
        -v "$PROJECT_DIR/src:/app/src" \
        -v "$PROJECT_DIR/test:/app/test" \
        -v "$PROJECT_DIR/examples:/app/examples" \
        -v "$PROJECT_DIR/CLAUDE.md:/app/CLAUDE.md" \
        -v "$PROJECT_DIR/README.md:/app/README.md" \
        -v "$CONTAINER_HOME:/home/$HOST_USER" \
        -v "$DATA_DIR:/data" \
        -w /app \
        -e HOME="/home/$HOST_USER" \
        -e ANTHROPIC_API_KEY \
        -e TZ="${TZ:-UTC}" \
        "$DEV_IMAGE" \
        zsh -c "$INIT_CMD; ${ARGS[*]}"
fi
