#!/bin/bash

# Poule end-user launcher
#
# Quick setup:
#   cp bin/poule ~/bin/poule && chmod +x ~/bin/poule
#   echo 'export POULE_PROJECT_DIR=~/Projects/my-coq-project' >> ~/.zshrc
#   echo 'export ANTHROPIC_API_KEY=sk-ant-...' >> ~/.zshrc
#
# Then just run: poule

set -euo pipefail

IMAGE="ghcr.io/ekirton/poule"

# ── Project directory ─────────────────────────────────────────────────────────
# Use POULE_PROJECT_DIR if set; otherwise fall back to the current directory.
PROJECT_DIR="${POULE_PROJECT_DIR:-$PWD}"

# ── Argument parsing ──────────────────────────────────────────────────────────
NO_PULL=false
NO_AUTO_UPDATE=false
REBUILD=false
ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --no-pull)
            NO_PULL=true
            shift
            ;;
        --no-auto-update)
            NO_AUTO_UPDATE=true
            shift
            ;;
        --rebuild)
            REBUILD=true
            shift
            ;;
        --help|-h)
            echo "Usage: poule [OPTIONS] [COMMAND]"
            echo ""
            echo "Run Claude Code in the Poule container with your Coq project mounted."
            echo ""
            echo "OPTIONS:"
            echo "  --no-pull          Skip pulling the latest image from the registry"
            echo "  --no-auto-update   Skip automatic Claude Code update check"
            echo "  --rebuild          Force update Claude Code in the image"
            echo "  --help, -h         Show this help message"
            echo ""
            echo "ENVIRONMENT:"
            echo "  POULE_PROJECT_DIR   Directory to mount (default: current directory)"
            echo "  ANTHROPIC_API_KEY   Optional — API key (Claude Max subscribers use OAuth login)"
            echo ""
            echo "EXAMPLES:"
            echo "  poule                  Start interactive shell in POULE_PROJECT_DIR"
            echo "  poule claude           Launch Claude Code directly"
            echo "  poule --no-pull        Skip image update check"
            echo "  poule --rebuild        Force update Claude Code version"
            echo "  poule coqc --version   Run a one-off command in the container"
            exit 0
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

# ── Preflight checks ──────────────────────────────────────────────────────────
if ! command -v docker >/dev/null 2>&1; then
    echo "Error: Docker is not installed. See https://docs.docker.com/get-docker/"
    exit 1
fi

if [ ! -d "$PROJECT_DIR" ]; then
    echo "Error: Project directory does not exist: $PROJECT_DIR"
    echo "Set POULE_PROJECT_DIR to a valid directory in your ~/.zshrc."
    exit 1
fi

if [ "$PROJECT_DIR" = "$HOME" ]; then
    echo "Error: Refusing to mount the home directory for security reasons."
    echo "Set POULE_PROJECT_DIR to a specific project directory."
    exit 1
fi

# ── Resolve latest Claude Code version ────────────────────────────────────────
CLAUDE_LATEST=""
if [ "$NO_AUTO_UPDATE" != true ]; then
    CLAUDE_LATEST=$(npm view @anthropic-ai/claude-code version 2>/dev/null || true)
fi

# ── Pull latest image ─────────────────────────────────────────────────────────
if [ "$NO_PULL" = false ] && [ "$REBUILD" = false ]; then
    docker pull --platform linux/amd64 "$IMAGE"
fi

# ── Version check and deferred update detection ──────────────────────────────
INSTALLED=$(docker inspect --format '{{index .Config.Labels "claude.code.version"}}' "$IMAGE" 2>/dev/null || true)
DEFERRED_UPDATE=false

if [ "$REBUILD" = true ]; then
    # Force rebuild now
    if [ -z "$CLAUDE_LATEST" ]; then
        CLAUDE_LATEST=$(npm view @anthropic-ai/claude-code version 2>/dev/null || true)
    fi
    if [ -n "$CLAUDE_LATEST" ]; then
        echo "Updating Claude Code to v${CLAUDE_LATEST}..."
        HOST_USER=$(id -un)
        HOST_UID_VAL=$(id -u)
        HOST_GID_VAL=$(id -g)
        TMPDIR_BUILD=$(mktemp -d)
        cat > "$TMPDIR_BUILD/Dockerfile" << DOCKERFILE
FROM --platform=linux/amd64 ${IMAGE}
USER root
RUN rm -rf /opt/claude /usr/local/bin/claude
ARG HOST_USER
ARG HOST_UID
ARG HOST_GID
USER \${HOST_USER}
RUN curl -fsSL https://claude.ai/install.sh | bash -s ${CLAUDE_LATEST}
USER root
RUN mv /home/\${HOST_USER}/.local/share/claude /opt/claude \
    && ln -sf "\$(ls -d /opt/claude/versions/* | head -1)" /usr/local/bin/claude \
    && chown -R \${HOST_UID}:\${HOST_GID} /opt/claude
LABEL claude.code.version=${CLAUDE_LATEST}
USER \${HOST_USER}
DOCKERFILE
        if docker build --platform linux/amd64 -t "$IMAGE" \
            --build-arg HOST_USER="$HOST_USER" \
            --build-arg HOST_UID="$HOST_UID_VAL" \
            --build-arg HOST_GID="$HOST_GID_VAL" \
            "$TMPDIR_BUILD"; then
            echo "Claude Code v${CLAUDE_LATEST} ready."
            INSTALLED="$CLAUDE_LATEST"
        else
            echo "Warning: Update failed."
        fi
        rm -rf "$TMPDIR_BUILD"
    else
        echo "Warning: Could not resolve latest Claude Code version (npm not available?)."
    fi
elif [ -n "$CLAUDE_LATEST" ] && [ -n "$INSTALLED" ] && [ "$INSTALLED" != "latest" ] && [ "$INSTALLED" != "$CLAUDE_LATEST" ]; then
    DEFERRED_UPDATE=true
fi

# ── Display Claude Code version ──────────────────────────────────────────────
if [ -n "$CLAUDE_LATEST" ] && [ -n "$INSTALLED" ] && [ "$INSTALLED" != "latest" ]; then
    if [ "$INSTALLED" = "$CLAUDE_LATEST" ]; then
        echo "Claude Code v${INSTALLED} (latest)"
    elif [ "$DEFERRED_UPDATE" = true ]; then
        printf "Claude Code v%s (\033[1;33mv%s available — will rebuild on exit\033[0m)\n" "$INSTALLED" "$CLAUDE_LATEST"
    fi
elif [ -n "$INSTALLED" ] && [ "$INSTALLED" != "latest" ]; then
    echo "Claude Code v${INSTALLED}"
fi

# ── Persistent home directory ─────────────────────────────────────────────────
CONTAINER_HOME="$HOME/poule-home"
if [ ! -d "$CONTAINER_HOME" ]; then
    echo "Creating Poule home directory: $CONTAINER_HOME"
    mkdir -p "$CONTAINER_HOME"
fi
chmod 700 "$CONTAINER_HOME"

# ── SSH key permissions (container requires strict modes) ─────────────────────
SSH_DIR="$CONTAINER_HOME/.ssh"
if [ -d "$SSH_DIR" ]; then
    chmod 700 "$SSH_DIR"
    find "$SSH_DIR" -maxdepth 1 -type f -name "id_*" ! -name "*.pub" -exec chmod 600 {} \;
    for f in "$SSH_DIR"/*.pub "$SSH_DIR/config" "$SSH_DIR/known_hosts" "$SSH_DIR/authorized_keys"; do
        [ -f "$f" ] && chmod 644 "$f"
    done
fi

# ── First-run: Claude Code settings ──────────────────────────────────────────
CLAUDE_DIR="$CONTAINER_HOME/.claude"
mkdir -p "$CLAUDE_DIR"

if [ ! -f "$CLAUDE_DIR/settings.json" ]; then
    echo "Initializing Claude Code settings..."
    cat > "$CLAUDE_DIR/settings.json" << 'EOF'
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "mcpServers": {
    "poule-mcp": {
      "type": "http",
      "url": "http://127.0.0.1:3000/mcp"
    }
  }
}
EOF
fi

if ! grep -q '"mcpServers"' "$CLAUDE_DIR/settings.json" 2>/dev/null; then
    python3 - "$CLAUDE_DIR/settings.json" << 'PYEOF'
import json, sys
path = sys.argv[1]
with open(path) as f:
    s = json.load(f)
s["mcpServers"] = {
    "poule-mcp": {"type": "http", "url": "http://127.0.0.1:3000/mcp"}
}
with open(path, "w") as f:
    json.dump(s, f, indent=2)
    f.write("\n")
PYEOF
fi

if ! grep -q '"statusLine"' "$CLAUDE_DIR/settings.json" 2>/dev/null; then
    python3 - "$CLAUDE_DIR/settings.json" << 'PYEOF'
import json, sys
path = sys.argv[1]
with open(path) as f:
    s = json.load(f)
s.setdefault("statusLine", {"type": "command", "command": "~/.claude/statusline.sh"})
with open(path, "w") as f:
    json.dump(s, f, indent=2)
    f.write("\n")
PYEOF
fi

if [ ! -f "$CLAUDE_DIR/statusline.sh" ]; then
    cat > "$CLAUDE_DIR/statusline.sh" << 'EOF'
#!/bin/bash
input=$(cat)
full_model=$(echo "$input" | jq -r '.model.display_name')
model=$(echo "$full_model" | awk '{print $1}')
ctx=$(echo "$input" | jq -r '(.context_window.used_percentage // 0) | round')
cost=$(echo "$input" | jq -r '.cost.total_cost_usd | . * 100 | round | . / 100')

model_lower=$(echo "$full_model" | tr '[:upper:]' '[:lower:]')
case "$model_lower" in
  *opus*)   model_color='\033[1;32m' ;;
  *sonnet*) model_color='\033[1;33m' ;;
  *haiku*)  model_color='\033[1;31m' ;;
  *)        model_color='\033[1;35m' ;;
esac

if [ "$ctx" -gt 80 ]; then
  ctx_color='\033[1;31m'
elif [ "$ctx" -gt 50 ]; then
  ctx_color='\033[1;33m'
else
  ctx_color='\033[1;35m'
fi

printf '\033[1;35m[dir=%s]\033[0m' "$(basename "$(pwd)")"
printf "${model_color}[model=%s]\033[0m" "$model"
printf "${ctx_color}[ctx=%s%%]\033[0m" "$ctx"
printf '\033[1;35m[cost=$%s]\033[0m\n' "$cost"
EOF
    chmod +x "$CLAUDE_DIR/statusline.sh"
fi

# ── First-run: zsh configuration ──────────────────────────────────────────────
if [ ! -f "$CONTAINER_HOME/.zshrc" ]; then
    cat > "$CONTAINER_HOME/.zshrc" << 'EOF'
# Poule container zsh configuration
_git_branch_colored() {
  local branch=$(git branch --show-current 2>/dev/null)
  if [ -n "$branch" ]; then
    if [ "$branch" = "main" ]; then
      echo "%F{red}[$branch]%f"
    else
      echo "%F{green}[$branch]%f"
    fi
  fi
}
setopt PROMPT_SUBST
PROMPT='%F{cyan}[Poule]%f $(_git_branch_colored)%F{blue}[%~]%f$ '
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
export PATH="/opt/opam/coq/bin:$HOME/.local/bin:$PATH"
export UV_LINK_MODE="copy"
alias claude='claude --dangerously-skip-permissions'
EOF
fi

# ── First-run: download Coq search index ──────────────────────────────────────
DATA_DIR="$CONTAINER_HOME/data"
mkdir -p "$DATA_DIR"

if [ ! -f "$DATA_DIR/index.db" ]; then
    echo ""
    echo "Downloading Coq search index (first run only)..."
    if docker run --rm \
        --platform linux/amd64 \
        -v "$DATA_DIR:/data" \
        --entrypoint sh \
        "$IMAGE" \
        -c 'uv run --project /app python -m Poule.cli download-index --output /data/index.db'; then
        echo "Index downloaded successfully."
    else
        echo "Warning: Index download failed. Retry from inside the container:"
        echo "  uv run --project /app python -m Poule.cli download-index --output ~/data/index.db"
    fi
    echo ""
fi

# ── Dynamic port scanning ────────────────────────────────────────────────────
HOST_PORT=3000
while lsof -iTCP:$HOST_PORT -sTCP:LISTEN -t >/dev/null 2>&1; do
    HOST_PORT=$((HOST_PORT + 1))
done

# ── Run ───────────────────────────────────────────────────────────────────────
# The entrypoint handles Claude symlinks, slash command provisioning, and
# MCP server lifecycle (start on entry, stop on exit via trap).
HOST_USER=$(id -un)

echo "Starting Poule in: $PROJECT_DIR"
echo ""
echo ""

if [ ${#ARGS[@]} -eq 0 ]; then
    # No command: entrypoint starts MCP server, syncs commands, launches Claude.
    docker run -it --rm \
        --platform linux/amd64 \
        -p $HOST_PORT:3000 \
        -v "$PROJECT_DIR:$PROJECT_DIR" \
        -v "$CONTAINER_HOME:/home/$HOST_USER" \
        -v "$DATA_DIR:/data" \
        -w "$PROJECT_DIR" \
        -e ANTHROPIC_API_KEY \
        -e HOME="/home/$HOST_USER" \
        -e TZ="${TZ:-UTC}" \
        "$IMAGE"
else
    # With command: entrypoint starts MCP server, syncs commands, then execs
    # the provided command.  MCP server stops on exit via entrypoint trap.
    docker run --rm \
        --platform linux/amd64 \
        -p $HOST_PORT:3000 \
        -v "$PROJECT_DIR:$PROJECT_DIR" \
        -v "$CONTAINER_HOME:/home/$HOST_USER" \
        -v "$DATA_DIR:/data" \
        -w "$PROJECT_DIR" \
        -e ANTHROPIC_API_KEY \
        -e HOME="/home/$HOST_USER" \
        -e TZ="${TZ:-UTC}" \
        "$IMAGE" \
        "${ARGS[@]}"
fi

# ── Deferred rebuild: update Claude Code for next launch ──────────────────────
if [ "$DEFERRED_UPDATE" = true ]; then
    # Re-check: another session may have already rebuilt while we were running
    CURRENT_VERSION=$(docker inspect --format '{{index .Config.Labels "claude.code.version"}}' "$IMAGE" 2>/dev/null || true)
    if [ "$CURRENT_VERSION" = "$CLAUDE_LATEST" ]; then
        echo "Claude Code v${CLAUDE_LATEST} already updated."
    else
        LOCK_DIR="$CONTAINER_HOME/.poule-rebuild.lock"

        acquire_rebuild_lock() {
            if mkdir "$LOCK_DIR" 2>/dev/null; then
                echo $$ > "$LOCK_DIR/pid"
                return 0
            fi
            # Lock exists — check if it's stale (owner process died)
            if [ -f "$LOCK_DIR/pid" ]; then
                LOCK_PID=$(cat "$LOCK_DIR/pid" 2>/dev/null)
                if [ -n "$LOCK_PID" ] && ! kill -0 "$LOCK_PID" 2>/dev/null; then
                    rm -rf "$LOCK_DIR"
                    if mkdir "$LOCK_DIR" 2>/dev/null; then
                        echo $$ > "$LOCK_DIR/pid"
                        return 0
                    fi
                fi
            fi
            return 1
        }

        if acquire_rebuild_lock; then
            trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM
            echo ""
            echo "Updating Claude Code: v${INSTALLED} → v${CLAUDE_LATEST}..."
            HOST_UID_VAL=$(id -u)
            HOST_GID_VAL=$(id -g)
            TMPDIR_BUILD=$(mktemp -d)
            cat > "$TMPDIR_BUILD/Dockerfile" << DOCKERFILE
FROM --platform=linux/amd64 ${IMAGE}
USER root
RUN rm -rf /opt/claude /usr/local/bin/claude
ARG HOST_USER
ARG HOST_UID
ARG HOST_GID
USER \${HOST_USER}
RUN curl -fsSL https://claude.ai/install.sh | bash -s ${CLAUDE_LATEST}
USER root
RUN mv /home/\${HOST_USER}/.local/share/claude /opt/claude \
    && ln -sf "\$(ls -d /opt/claude/versions/* | head -1)" /usr/local/bin/claude \
    && chown -R \${HOST_UID}:\${HOST_GID} /opt/claude
LABEL claude.code.version=${CLAUDE_LATEST}
USER \${HOST_USER}
DOCKERFILE
            if docker build --platform linux/amd64 -t "$IMAGE" \
                --build-arg HOST_USER="$HOST_USER" \
                --build-arg HOST_UID="$HOST_UID_VAL" \
                --build-arg HOST_GID="$HOST_GID_VAL" \
                "$TMPDIR_BUILD"; then
                echo "Claude Code v${CLAUDE_LATEST} ready for next launch."
            else
                echo "Warning: Update failed. Will retry on next launch."
            fi
            rm -rf "$TMPDIR_BUILD"
            rm -rf "$LOCK_DIR"
            trap - EXIT INT TERM
        else
            echo "Another session is already rebuilding Claude Code. Skipping."
        fi
    fi
fi
