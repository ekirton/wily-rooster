#!/bin/bash

# Poule Developer Launcher
# Usage: poule-dev [--rebuild] [--no-auto-update] [command]
# Builds and runs a dev container with the project root mounted from the host.
# Must be run from the poule project root.

set -euo pipefail

# Guard: these launchers must run on the host, not inside the container.
if [ -f /.dockerenv ]; then
    echo "Error: $(basename "$0") is a host launcher and cannot run inside the container." >&2
    exit 1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$SCRIPT_DIR/.."
DEV_IMAGE="poule:dev"

# Parse arguments
REBUILD=false
NO_AUTO_UPDATE=false
ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --rebuild)
            REBUILD=true
            shift
            ;;
        --no-auto-update)
            NO_AUTO_UPDATE=true
            shift
            ;;
        --help|-h)
            echo "Usage: poule-dev [OPTIONS] [COMMAND]"
            echo ""
            echo "Run a dev container with the project root bind-mounted for full dev access."
            echo "Builds the dev image automatically on first run (uses Dockerfile app-deps stage)."
            echo ""
            echo "OPTIONS:"
            echo "  --rebuild          Force rebuild the dev image"
            echo "  --no-auto-update   Skip automatic Claude Code update check"
            echo "  --help, -h         Show this help message"
            echo ""
            echo "EXAMPLES:"
            echo "  poule-dev                         Start interactive dev shell"
            echo "  poule-dev uv run pytest            Run tests with live-mounted source"
            echo "  poule-dev coqc --version            Run a command in the container"
            echo "  poule-dev --rebuild                 Rebuild the dev image and start shell"
            exit 0
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

# Must be run from the poule project root
if [ ! -d "$PROJECT_DIR/src/Poule" ]; then
    echo "Error: must be run from the Poule project root."
    echo "Expected to find src/Poule/ relative to bin/poule-dev"
    exit 1
fi

# Get host user info for proper file ownership
HOST_UID=$(id -u)
HOST_GID=$(id -g)
HOST_USER=$(id -un)
HOST_GROUP=$(id -gn)

# ── Resolve latest Claude Code version ────────────────────────────────────────
CLAUDE_LATEST=""
if [ "$NO_AUTO_UPDATE" != true ]; then
    CLAUDE_LATEST=$(npm view @anthropic-ai/claude-code version 2>/dev/null || true)
fi

# ── Build dev image if missing or --rebuild requested ─────────────────────────
DEV_IMAGE_EXISTS=$(docker images --format "{{.Repository}}:{{.Tag}}" | grep -c "^poule:dev$" || echo "0")
NEED_BUILD=false
BUILD_REASON=""
DEFERRED_UPDATE=false

DOCKERFILE_HASH=$(sha256sum "$PROJECT_DIR/Dockerfile" | cut -d' ' -f1)

if [ "$DEV_IMAGE_EXISTS" -eq 0 ]; then
    NEED_BUILD=true
    BUILD_REASON="initial"
elif [ "$REBUILD" = true ]; then
    NEED_BUILD=true
    BUILD_REASON="requested"
elif [ "$DOCKERFILE_HASH" != "$(docker inspect --format '{{index .Config.Labels "poule.dockerfile.hash"}}' "$DEV_IMAGE" 2>/dev/null || true)" ]; then
    NEED_BUILD=true
    BUILD_REASON="Dockerfile changed"
elif [ -n "$CLAUDE_LATEST" ]; then
    INSTALLED=$(docker inspect --format '{{index .Config.Labels "claude.code.version"}}' "$DEV_IMAGE" 2>/dev/null || true)
    if [ -n "$INSTALLED" ] && [ "$INSTALLED" != "latest" ] && [ "$INSTALLED" != "$CLAUDE_LATEST" ]; then
        DEFERRED_UPDATE=true
    fi
fi

if [ "$NEED_BUILD" = true ]; then
    echo "Building dev image (app-deps stage) with user=$HOST_USER($HOST_UID), group=$HOST_GROUP($HOST_GID)..."
    docker build \
        --target app-deps \
        --build-arg HOST_UID="$HOST_UID" \
        --build-arg HOST_GID="$HOST_GID" \
        --build-arg HOST_USER="$HOST_USER" \
        --build-arg HOST_GROUP="$HOST_GROUP" \
        --build-arg CLAUDE_CODE_VERSION="${CLAUDE_LATEST:-latest}" \
        --label "poule.dockerfile.hash=$DOCKERFILE_HASH" \
        -t "$DEV_IMAGE" \
        "$PROJECT_DIR"
fi

# ── Display Claude Code version ──────────────────────────────────────────────
INSTALLED=$(docker inspect --format '{{index .Config.Labels "claude.code.version"}}' "$DEV_IMAGE" 2>/dev/null || true)
if [ -n "$CLAUDE_LATEST" ] && [ -n "$INSTALLED" ] && [ "$INSTALLED" != "latest" ]; then
    if [ "$INSTALLED" = "$CLAUDE_LATEST" ]; then
        echo "Claude Code v${INSTALLED} (latest)"
    elif [ "$DEFERRED_UPDATE" = true ]; then
        printf "Claude Code v%s (\033[1;33mv%s available — will rebuild on exit\033[0m)\n" "$INSTALLED" "$CLAUDE_LATEST"
    fi
elif [ -n "$INSTALLED" ] && [ "$INSTALLED" != "latest" ]; then
    echo "Claude Code v${INSTALLED}"
fi

# ── Persistent home directory ─────────────────────────────────────────────────
CONTAINER_HOME="$HOME/poule-home"
if [ ! -d "$CONTAINER_HOME" ]; then
    echo "Creating Poule home directory: $CONTAINER_HOME"
    mkdir -p "$CONTAINER_HOME"
fi
chmod 700 "$CONTAINER_HOME"

# Fix SSH key permissions (macOS mounts may have overly permissive modes)
SSH_DIR="$CONTAINER_HOME/.ssh"
if [ -d "$SSH_DIR" ]; then
    chmod 700 "$SSH_DIR"
    find "$SSH_DIR" -maxdepth 1 -type f -name "id_*" ! -name "*.pub" -exec chmod 600 {} \;
    for f in "$SSH_DIR"/*.pub "$SSH_DIR/config" "$SSH_DIR/known_hosts" "$SSH_DIR/authorized_keys"; do
        [ -f "$f" ] && chmod 644 "$f"
    done
fi

# Ensure Claude Code settings and statusline script exist in persistent home
CLAUDE_DIR="$CONTAINER_HOME/.claude"
mkdir -p "$CLAUDE_DIR"

if [ ! -f "$CLAUDE_DIR/settings.json" ]; then
    echo "Initializing Claude Code settings..."
    cat > "$CLAUDE_DIR/settings.json" << 'EOF'
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "mcpServers": {
    "poule-mcp": {
      "type": "http",
      "url": "http://127.0.0.1:3000/mcp"
    }
  }
}
EOF
fi

python3 - "$CLAUDE_DIR/settings.json" << 'PYEOF'
import json, sys
path = sys.argv[1]
with open(path) as f:
    s = json.load(f)
servers = s.setdefault("mcpServers", {})
# Migrate old server name
if "poule" in servers and "poule-mcp" not in servers:
    servers["poule-mcp"] = servers.pop("poule")
servers.setdefault("poule-mcp", {"type": "http", "url": "http://127.0.0.1:3000/mcp"})
servers.pop("mcp-mermaid", None)
with open(path, "w") as f:
    json.dump(s, f, indent=2)
    f.write("\n")
PYEOF

if ! grep -q '"statusLine"' "$CLAUDE_DIR/settings.json" 2>/dev/null; then
    python3 - "$CLAUDE_DIR/settings.json" << 'PYEOF'
import json, sys
path = sys.argv[1]
with open(path) as f:
    s = json.load(f)
s.setdefault("statusLine", {"type": "command", "command": "~/.claude/statusline.sh"})
with open(path, "w") as f:
    json.dump(s, f, indent=2)
    f.write("\n")
PYEOF
fi

if [ ! -f "$CLAUDE_DIR/statusline.sh" ] || [ "$PROJECT_DIR/docker/statusline.sh" -nt "$CLAUDE_DIR/statusline.sh" ]; then
    cp "$PROJECT_DIR/docker/statusline.sh" "$CLAUDE_DIR/statusline.sh"
    chmod +x "$CLAUDE_DIR/statusline.sh"
fi

# Repair incomplete plugin caches
PLUGIN_CACHE="$CLAUDE_DIR/plugins/cache"
PLUGIN_MARKETPLACE="$CLAUDE_DIR/plugins/marketplaces"

if [ -d "$PLUGIN_CACHE" ] && [ -d "$PLUGIN_MARKETPLACE" ]; then
    for marketplace_dir in "$PLUGIN_MARKETPLACE"/*/; do
        marketplace_name=$(basename "$marketplace_dir")
        plugins_source="$marketplace_dir/plugins"
        cache_base="$PLUGIN_CACHE/$marketplace_name"
        [ -d "$plugins_source" ] && [ -d "$cache_base" ] || continue

        for plugin_cache_dir in "$cache_base"/*/; do
            plugin_name=$(basename "$plugin_cache_dir")
            plugin_source="$plugins_source/$plugin_name"
            [ -d "$plugin_source" ] || continue

            for version_dir in "$plugin_cache_dir"/*/; do
                [ -d "$version_dir" ] || continue
                for source_subdir in "$plugin_source"/*/; do
                    [ -d "$source_subdir" ] || continue
                    if [ ! -d "$version_dir/$(basename "$source_subdir")" ]; then
                        echo "Repairing incomplete plugin cache: $plugin_name"
                        rm -rf "$version_dir"
                        break
                    fi
                done
            done
        done
    done
fi

# Create data directory and download index if needed
DATA_DIR="$CONTAINER_HOME/data"
mkdir -p "$DATA_DIR"

if [ ! -f "$DATA_DIR/index.db" ]; then
    echo ""
    if [ -f "$PROJECT_DIR/index.db" ]; then
        echo "Copying local index.db into data directory..."
        cp "$PROJECT_DIR/index.db" "$DATA_DIR/index.db"
        echo "Index copied successfully."
    else
        echo "No local index.db found — downloading from latest GitHub release..."
        if docker run --rm \
            -v "$PROJECT_DIR:/poule" \
            -v "$DATA_DIR:/data" \
            --entrypoint sh \
            "$DEV_IMAGE" \
            -c 'uv run --project /poule python -m Poule.cli download-index --output /data/index.db'; then
            echo "Index downloaded successfully."
        else
            echo "Warning: Index download failed. You can retry later from inside the container:"
            echo "  uv run --project /poule python -m Poule.cli download-index --output ~/data/index.db"
        fi
    fi
    echo ""
fi

# Initialize zsh configuration in persistent home
if [ ! -f "$CONTAINER_HOME/.zshrc" ]; then
    cat > "$CONTAINER_HOME/.zshrc" << 'EOF'
# Poule container zsh configuration
_git_branch_colored() {
  local branch=$(git branch --show-current 2>/dev/null)
  if [ -n "$branch" ]; then
    if [ "$branch" = "main" ]; then
      echo "%F{red}[$branch]%f"
    else
      echo "%F{green}[$branch]%f"
    fi
  fi
}
setopt PROMPT_SUBST
PROMPT='%F{cyan}[Poule]%f $(_git_branch_colored)%F{blue}[%~]%f$ '
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
export PATH="/opt/opam/coq/bin:$HOME/.local/bin:$PATH"
export UV_LINK_MODE="copy"
alias claude='claude --dangerously-skip-permissions'
EOF
fi

# ── Find a free host port for the MCP server / diagram viewer ────────────────
HOST_PORT=3000
while lsof -iTCP:$HOST_PORT -sTCP:LISTEN -t >/dev/null 2>&1; do
    HOST_PORT=$((HOST_PORT + 1))
done

# ── Run ───────────────────────────────────────────────────────────────────────
# The dev image (app-deps target) has no entrypoint, so we handle init inline.
# - Symlink Claude Code from /opt into the persistent home
# - Symlink live-mounted commands/ for immediate edits
# - Start MCP server, stop on exit via trap
INIT_CMD='mkdir -p ~/.local/bin ~/.local/share ~/.claude/commands && ln -sf "$(ls -d /opt/claude/versions/* | head -1)" ~/.local/bin/claude && ln -sf /opt/claude ~/.local/share/claude && for f in /poule/commands/*.md; do [ -f "$f" ] && [ "$(basename "$f")" != "CLAUDE.md" ] && ln -sf "$f" ~/.claude/commands/; done && if [ -d ~/.gnupg ]; then rm -f ~/.gnupg/S.gpg-agent*; gpg-agent --daemon 2>/dev/null; fi && poule-mcp start && trap "poule-mcp stop 2>/dev/null" EXIT INT TERM'

# Run container with project root mounted
if [ ${#ARGS[@]} -eq 0 ]; then
    echo "Starting Poule dev environment (project root mount)"
    echo ""
    echo ""
    docker run -it --rm \
        --user "$HOST_UID:$HOST_GID" \
        -p $HOST_PORT:3000 \
        -v "$PROJECT_DIR:/poule" \
        -v "$CONTAINER_HOME:/home/$HOST_USER" \
        -v "$DATA_DIR:/data" \
        -w /poule \
        -e HOME="/home/$HOST_USER" \
        -e ANTHROPIC_API_KEY \
        -e TZ="${TZ:-UTC}" \
        "$DEV_IMAGE" \
        zsh -c "$INIT_CMD; zsh; poule-mcp stop 2>/dev/null"
else
    docker run --rm \
        --user "$HOST_UID:$HOST_GID" \
        -p $HOST_PORT:3000 \
        -v "$PROJECT_DIR:/poule" \
        -v "$CONTAINER_HOME:/home/$HOST_USER" \
        -v "$DATA_DIR:/data" \
        -w /poule \
        -e HOME="/home/$HOST_USER" \
        -e ANTHROPIC_API_KEY \
        -e TZ="${TZ:-UTC}" \
        "$DEV_IMAGE" \
        zsh -c "$INIT_CMD; ${ARGS[*]}"
fi

# ── Deferred rebuild: update Claude Code for next launch ──────────────────────
if [ "$DEFERRED_UPDATE" = true ]; then
    # Re-check: another session may have already rebuilt while we were running
    CURRENT_VERSION=$(docker inspect --format '{{index .Config.Labels "claude.code.version"}}' "$DEV_IMAGE" 2>/dev/null || true)
    if [ "$CURRENT_VERSION" = "$CLAUDE_LATEST" ]; then
        echo "Claude Code v${CLAUDE_LATEST} already updated."
    else
        LOCK_DIR="$CONTAINER_HOME/.poule-rebuild.lock"

        acquire_rebuild_lock() {
            if mkdir "$LOCK_DIR" 2>/dev/null; then
                echo $$ > "$LOCK_DIR/pid"
                return 0
            fi
            # Lock exists — check if it's stale (owner process died)
            if [ -f "$LOCK_DIR/pid" ]; then
                LOCK_PID=$(cat "$LOCK_DIR/pid" 2>/dev/null)
                if [ -n "$LOCK_PID" ] && ! kill -0 "$LOCK_PID" 2>/dev/null; then
                    rm -rf "$LOCK_DIR"
                    if mkdir "$LOCK_DIR" 2>/dev/null; then
                        echo $$ > "$LOCK_DIR/pid"
                        return 0
                    fi
                fi
            fi
            return 1
        }

        if acquire_rebuild_lock; then
            trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM
            echo ""
            echo "Updating Claude Code: v${INSTALLED} → v${CLAUDE_LATEST}..."
            if docker build \
                --target app-deps \
                --build-arg HOST_UID="$HOST_UID" \
                --build-arg HOST_GID="$HOST_GID" \
                --build-arg HOST_USER="$HOST_USER" \
                --build-arg HOST_GROUP="$HOST_GROUP" \
                --build-arg CLAUDE_CODE_VERSION="${CLAUDE_LATEST}" \
                --build-arg CACHEBUST_CLAUDE="$(date +%s)" \
                --label "poule.dockerfile.hash=$DOCKERFILE_HASH" \
                -t "$DEV_IMAGE" \
                "$PROJECT_DIR"; then
                echo "Claude Code v${CLAUDE_LATEST} ready for next launch."
            else
                echo "Warning: Update failed. Will retry on next launch."
            fi
            rm -rf "$LOCK_DIR"
            trap - EXIT INT TERM
        else
            echo "Another session is already rebuilding Claude Code. Skipping."
        fi
    fi
fi
