#!/bin/bash

# Poule Launcher
# Usage: poule [--rebuild|--rebuild-all] [--no-auto-update] [command]
# Runs Claude Code in a Docker container with the Coq toolchain and Poule MCP server

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$SCRIPT_DIR/.."

# Parse arguments
REBUILD=false
REBUILD_ALL=false
NO_AUTO_UPDATE=false
ARGS=()

while [[ $# -gt 0 ]]; do
    case $1 in
        --rebuild)
            REBUILD=true
            shift
            ;;
        --rebuild-all)
            REBUILD=true
            REBUILD_ALL=true
            shift
            ;;
        --no-auto-update)
            NO_AUTO_UPDATE=true
            shift
            ;;
        --help|-h)
            echo "Usage: poule [OPTIONS] [COMMAND]"
            echo ""
            echo "Run Claude Code in a container with Coq and the Poule MCP server."
            echo ""
            echo "OPTIONS:"
            echo "  --rebuild          Update Claude CLI and rebuild (uses cache)"
            echo "  --rebuild-all      Full rebuild from scratch (no cache)"
            echo "  --no-auto-update   Skip automatic rebuild when new version is detected"
            echo "  --help, -h         Show this help message"
            echo ""
            echo "EXAMPLES:"
            echo "  poule                         Start interactive shell"
            echo "  poule claude                   Run Claude Code directly"
            echo "  poule --rebuild                Update Claude CLI"
            echo "  poule coqc --version           Run a command in the container"
            exit 0
            ;;
        *)
            ARGS+=("$1")
            shift
            ;;
    esac
done

# Get the current working directory
CURRENT_DIR="$(pwd)"

# Security check: don't allow mounting home directory
if [ "$CURRENT_DIR" = "$HOME" ]; then
    echo "Error: Cannot mount home directory for security reasons."
    echo "Please run from within a specific project directory."
    echo "Example: cd ~/Projects/my-coq-project && poule"
    exit 1
fi

# Get host user info for proper file ownership
HOST_UID=$(id -u)
HOST_GID=$(id -g)
HOST_USER=$(id -un)
HOST_GROUP=$(id -gn)

# Persistent home directory
CONTAINER_HOME="$HOME/poule-home"
FIRST_RUN="false"
if [ ! -d "$CONTAINER_HOME" ]; then
    FIRST_RUN="true"
    echo "Creating Poule home directory: $CONTAINER_HOME"
    mkdir -p "$CONTAINER_HOME"
fi
chmod 700 "$CONTAINER_HOME"

# Resolve latest Claude Code version from npm (used for builds and update checks)
CLAUDE_LATEST=""
if command -v npm >/dev/null 2>&1; then
    CLAUDE_LATEST=$(npm view @anthropic-ai/claude-code version 2>/dev/null || echo "")
fi

# Determine if a build is needed
IMAGE_EXISTS=$(docker images --format "{{.Repository}}:{{.Tag}}" | grep -c "poule:latest" || echo "0")
NEED_BUILD=false
BUILD_REASON=""
DEFERRED_UPDATE=false

if [ "$IMAGE_EXISTS" -eq 0 ]; then
    NEED_BUILD=true
    BUILD_REASON="initial"
elif [ "$REBUILD" = true ]; then
    NEED_BUILD=true
    BUILD_REASON="requested"
elif [ -n "$CLAUDE_LATEST" ] && [ "$NO_AUTO_UPDATE" != true ]; then
    INSTALLED=$(docker inspect --format '{{index .Config.Labels "claude.code.version"}}' poule:latest 2>/dev/null)
    if [ -n "$INSTALLED" ] && [ "$INSTALLED" != "$CLAUDE_LATEST" ] && [ "$INSTALLED" != "latest" ]; then
        DEFERRED_UPDATE=true
    fi
fi

if [ "$NEED_BUILD" = true ]; then
    BUILD_ARGS=(
        --build-arg HOST_UID="$HOST_UID"
        --build-arg HOST_GID="$HOST_GID"
        --build-arg HOST_USER="$HOST_USER"
        --build-arg HOST_GROUP="$HOST_GROUP"
        --build-arg CLAUDE_CODE_VERSION="${CLAUDE_LATEST:-latest}"
    )

    if [ "$REBUILD_ALL" = true ]; then
        echo "Full rebuild (no cache) with user=$HOST_USER($HOST_UID)..."
        BUILD_ARGS+=(--no-cache)
    elif [ "$REBUILD" = true ]; then
        echo "Rebuilding Poule image with user=$HOST_USER($HOST_UID)..."
        BUILD_ARGS+=(--build-arg CACHEBUST_CLAUDE="$(date +%s)")
    else
        echo "Building Poule container image with user=$HOST_USER($HOST_UID)..."
    fi

    if ! docker build -t poule "${BUILD_ARGS[@]}" "$PROJECT_DIR"; then
        echo "Error: Build failed."
        exit 1
    fi
fi

# Display Claude Code version info
INSTALLED=$(docker inspect --format '{{index .Config.Labels "claude.code.version"}}' poule:latest 2>/dev/null)
if [ -n "$CLAUDE_LATEST" ] && [ -n "$INSTALLED" ] && [ "$INSTALLED" != "latest" ]; then
    if [ "$INSTALLED" = "$CLAUDE_LATEST" ]; then
        echo "Claude Code v${INSTALLED} (latest)"
    elif [ "$DEFERRED_UPDATE" = true ]; then
        printf "Claude Code v%s (\033[1;33mv%s available — will rebuild on exit\033[0m)\n" "$INSTALLED" "$CLAUDE_LATEST"
    else
        echo "Claude Code v${INSTALLED} (v${CLAUDE_LATEST} available — run with --rebuild to update)"
    fi
elif [ -n "$INSTALLED" ] && [ "$INSTALLED" != "latest" ]; then
    echo "Claude Code v${INSTALLED}"
fi

# Fix SSH key permissions (macOS mounts may have overly permissive modes)
SSH_DIR="$CONTAINER_HOME/.ssh"
if [ -d "$SSH_DIR" ]; then
    chmod 700 "$SSH_DIR"
    find "$SSH_DIR" -maxdepth 1 -type f -name "id_*" ! -name "*.pub" -exec chmod 600 {} \;
    for f in "$SSH_DIR"/*.pub "$SSH_DIR/config" "$SSH_DIR/known_hosts" "$SSH_DIR/authorized_keys"; do
        [ -f "$f" ] && chmod 644 "$f"
    done
fi

# Ensure Claude Code settings and statusline script exist in persistent home
CLAUDE_DIR="$CONTAINER_HOME/.claude"
mkdir -p "$CLAUDE_DIR"

if [ ! -f "$CLAUDE_DIR/settings.json" ]; then
    echo "Initializing Claude Code settings..."
    cat > "$CLAUDE_DIR/settings.json" << 'EOF'
{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  }
}
EOF
fi

if [ ! -f "$CLAUDE_DIR/statusline.sh" ] || [ "$PROJECT_DIR/docker/statusline.sh" -nt "$CLAUDE_DIR/statusline.sh" ]; then
    cp "$PROJECT_DIR/docker/statusline.sh" "$CLAUDE_DIR/statusline.sh"
    chmod +x "$CLAUDE_DIR/statusline.sh"
fi

# Auto-configure MCP server
if [ ! -f "$CLAUDE_DIR/mcp.json" ]; then
    echo "Configuring Poule MCP server..."
    cat > "$CLAUDE_DIR/mcp.json" << 'EOF'
{
  "mcpServers": {
    "coq-search": {
      "command": "uv",
      "args": ["run", "--project", "/app", "python", "-m", "poule.server", "--db", "/data/index.db"]
    }
  }
}
EOF
fi

# Repair incomplete plugin caches
PLUGIN_CACHE="$CLAUDE_DIR/plugins/cache"
PLUGIN_MARKETPLACE="$CLAUDE_DIR/plugins/marketplaces"

if [ -d "$PLUGIN_CACHE" ] && [ -d "$PLUGIN_MARKETPLACE" ]; then
    for marketplace_dir in "$PLUGIN_MARKETPLACE"/*/; do
        marketplace_name=$(basename "$marketplace_dir")
        plugins_source="$marketplace_dir/plugins"
        cache_base="$PLUGIN_CACHE/$marketplace_name"
        [ -d "$plugins_source" ] && [ -d "$cache_base" ] || continue

        for plugin_cache_dir in "$cache_base"/*/; do
            plugin_name=$(basename "$plugin_cache_dir")
            plugin_source="$plugins_source/$plugin_name"
            [ -d "$plugin_source" ] || continue

            for version_dir in "$plugin_cache_dir"/*/; do
                [ -d "$version_dir" ] || continue
                for source_subdir in "$plugin_source"/*/; do
                    [ -d "$source_subdir" ] || continue
                    if [ ! -d "$version_dir/$(basename "$source_subdir")" ]; then
                        echo "Repairing incomplete plugin cache: $plugin_name"
                        rm -rf "$version_dir"
                        break
                    fi
                done
            done
        done
    done
fi

# Create data directory and download index if needed
DATA_DIR="$CONTAINER_HOME/data"
mkdir -p "$DATA_DIR"

if [ ! -f "$DATA_DIR/index.db" ]; then
    echo ""
    echo "Downloading Coq search index (first run only)..."
    if docker run --rm \
        -v "$DATA_DIR:/data" \
        --entrypoint sh \
        poule \
        -c 'uv run --project /app python -m poule.cli download-index --output /data/index.db'; then
        echo "Index downloaded successfully."
    else
        echo "Warning: Index download failed. You can retry later from inside the container:"
        echo "  uv run --project /app python -m poule.cli download-index --output ~/data/index.db"
    fi
    echo ""
fi

# Initialize zsh configuration in persistent home
if [ ! -f "$CONTAINER_HOME/.zshrc" ]; then
    cat > "$CONTAINER_HOME/.zshrc" << 'EOF'
# Poule container zsh configuration
_git_branch_colored() {
  local branch=$(git branch --show-current 2>/dev/null)
  if [ -n "$branch" ]; then
    if [ "$branch" = "main" ]; then
      echo "%F{red}[$branch]%f"
    else
      echo "%F{green}[$branch]%f"
    fi
  fi
}
setopt PROMPT_SUBST
PROMPT='%F{cyan}[poule]%f $(_git_branch_colored)%F{blue}[%~]%f$ '
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
export PATH="/opt/opam/coq/bin:$HOME/.local/bin:$PATH"
export UV_LINK_MODE="copy"
alias claude='claude --dangerously-skip-permissions'
EOF
fi

# Claude symlink restoration command (needed because home mount hides build-time symlinks)
INIT_CMD='mkdir -p ~/.local/bin ~/.local/share && ln -sf "$(ls -d /opt/claude/versions/* | head -1)" ~/.local/bin/claude && ln -sf /opt/claude ~/.local/share/claude'

# Run container
if [ ${#ARGS[@]} -eq 0 ]; then
    echo "Starting Poule environment in: $CURRENT_DIR"
    docker run -it --rm \
        -v "$CURRENT_DIR:$CURRENT_DIR" \
        -v "$CONTAINER_HOME:/home/$HOST_USER" \
        -v "$DATA_DIR:/data" \
        -w "$CURRENT_DIR" \
        -e ANTHROPIC_API_KEY \
        -e TZ="${TZ:-UTC}" \
        poule \
        zsh -c "$INIT_CMD; exec zsh"
else
    docker run --rm \
        -v "$CURRENT_DIR:$CURRENT_DIR" \
        -v "$CONTAINER_HOME:/home/$HOST_USER" \
        -v "$DATA_DIR:/data" \
        -w "$CURRENT_DIR" \
        -e ANTHROPIC_API_KEY \
        -e TZ="${TZ:-UTC}" \
        poule \
        zsh -c "$INIT_CMD; ${ARGS[*]}"
fi

# Deferred rebuild: update the container image for next launch
if [ "$DEFERRED_UPDATE" = true ]; then
    CURRENT_VERSION=$(docker inspect --format '{{index .Config.Labels "claude.code.version"}}' poule:latest 2>/dev/null)
    if [ "$CURRENT_VERSION" = "$CLAUDE_LATEST" ]; then
        echo "Claude Code v${CLAUDE_LATEST} already updated."
    else
        LOCK_DIR="$CONTAINER_HOME/.poule-rebuild.lock"

        acquire_rebuild_lock() {
            if mkdir "$LOCK_DIR" 2>/dev/null; then
                echo $$ > "$LOCK_DIR/pid"
                return 0
            fi
            if [ -f "$LOCK_DIR/pid" ]; then
                LOCK_PID=$(cat "$LOCK_DIR/pid" 2>/dev/null)
                if [ -n "$LOCK_PID" ] && ! kill -0 "$LOCK_PID" 2>/dev/null; then
                    rm -rf "$LOCK_DIR"
                    if mkdir "$LOCK_DIR" 2>/dev/null; then
                        echo $$ > "$LOCK_DIR/pid"
                        return 0
                    fi
                fi
            fi
            return 1
        }

        if acquire_rebuild_lock; then
            trap 'rm -rf "$LOCK_DIR"' EXIT INT TERM
            echo ""
            echo "Updating Claude Code: v${INSTALLED} → v${CLAUDE_LATEST}..."
            BUILD_ARGS=(
                --build-arg HOST_UID="$HOST_UID"
                --build-arg HOST_GID="$HOST_GID"
                --build-arg HOST_USER="$HOST_USER"
                --build-arg HOST_GROUP="$HOST_GROUP"
                --build-arg CLAUDE_CODE_VERSION="${CLAUDE_LATEST}"
                --build-arg CACHEBUST_CLAUDE="$(date +%s)"
            )
            if docker build -t poule "${BUILD_ARGS[@]}" "$PROJECT_DIR"; then
                echo "Claude Code v${CLAUDE_LATEST} ready for next launch."
            else
                echo "Warning: Update failed. Will retry on next launch."
            fi
            rm -rf "$LOCK_DIR"
            trap - EXIT INT TERM
        else
            echo "Another session is already rebuilding. Skipping."
        fi
    fi
fi
